{
  "name": "six-degrees-player",
  "version": "1.0.0",
  "description": "KEXP Six Degrees Week Player — Every song connected to the last",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:data": "node scripts/build-data.js",
    "build:web": "node scripts/build-data.js && vite build",
    "electron": "electron .",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "org.kexp.six-degrees-player",
    "productName": "Six Degrees Player",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["portable"]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1"
  }
}
